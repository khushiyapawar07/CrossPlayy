# MongoDB Connection (works with MongoDB Compass)
# Atlas example:
# MONGODB_URI=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/crossplayy?retryWrites=true&w=majority
# Local Compass/Community Server example:
# MONGODB_URI=mongodb://127.0.0.1:27017/crossplayy
MONGODB_URI=

# JWT Secret
JWT_SECRET=your_jwt_secret_key_here_change_in_production

# Server Port
PORT=5000

# Node Environment
NODE_ENV=development
